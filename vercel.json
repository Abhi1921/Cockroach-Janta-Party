{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).(webp|png|jpg|css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/vision", "destination": "/vision.html" },
    { "source": "/manifesto", "destination": "/manifesto.html" },
    { "source": "/articles", "destination": "/articles.html" },
    { "source": "/protests", "destination": "/protests.html" },
    { "source": "/join", "destination": "/join.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/donate", "destination": "/donate.html" },
    { "source": "/gallery", "destination": "/gallery.html" },
    { "source": "/members", "destination": "/members.html" },
    { "source": "/issues", "destination": "/issues.html" },
    { "source": "/tracker", "destination": "/tracker.html" },
    { "source": "/raise-issue", "destination": "/raise-issue.html" },
    { "source": "/revolutionaries", "destination": "/revolutionaries.html" },
    { "source": "/terms", "destination": "/terms.html" }
  ]
}
